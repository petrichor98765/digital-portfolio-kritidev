{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/[^.]+$",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_SITE_TITLE": "Kriti Chinta - Software Developer",
    "VITE_SITE_DESCRIPTION": "Creating beautiful, performant web experiences"
  }
}
